<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Force dark mode only — this app is themed after the night-time
      stealth of Nige Jouzu no Wakagimi / The Elusive Samurai.
    -->
    <style name="Theme.AutoFillList" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">@color/ink_black</item>
        <item name="android:statusBarColor">@color/ink_black</item>
        <item name="android:navigationBarColor">@color/ink_black</item>
        <item name="android:windowLightStatusBar">false</item>

        <item name="colorPrimary">@color/samurai_red</item>
        <item name="colorPrimaryVariant">@color/samurai_red_dark</item>
        <item name="colorOnPrimary">@color/paper_white</item>
        <item name="colorSecondary">@color/sakura_gold</item>
        <item name="colorOnSecondary">@color/ink_black</item>
        <item name="colorSurface">@color/ink_surface</item>
        <item name="colorOnSurface">@color/paper_white</item>
        <item name="colorBackground">@color/ink_black</item>
        <item name="colorOnBackground">@color/paper_white</item>
        <item name="android:textColorPrimary">@color/paper_white</item>
        <item name="android:textColorSecondary">@color/mist_gray</item>
    </style>
</resources>
