<resources>
    <string name="app_name">Soojiso · Yami\'s AutoFill</string>
    <string name="app_tagline">逃げ上手の夜 — The Elusive Samurai</string>
    <string name="app_author">by YAMI</string>
    <string name="app_hero">TOKIYUKI</string>
    <string name="app_hero_sub">Hōjō Tokiyuki · 北条 時行</string>
    <string name="app_motto">Strike fast. Fill faster.</string>

    <string name="accessibility_service_description">Types the next item from your list into the first or second input field of whichever app is in the foreground when you tap a floating button.</string>

    <!-- Main list card -->
    <string name="title_list">Auto-fill list (one item per line)</string>
    <string name="list_desc">Tap ① or ② on the floating panel to fill the next item into the first or second input field. The used line is removed from the list.</string>
    <string name="hint_list">355123456789012\n355123456789013\n355123456789014</string>
    <string name="save">Save</string>
    <string name="clear">Clear</string>

    <!-- Keep list card -->
    <string name="title_keep">Keep list</string>
    <string name="keep_desc">Tap ★ on the floating panel right after a fill to copy the just-used item here. Values you don\'t tap ★ for are discarded permanently.</string>
    <string name="hint_keep">Kept items will appear here, one per line.</string>

    <!-- Permissions -->
    <string name="permissions_title">Permissions</string>
    <string name="perm_accessibility">1. Accessibility Service</string>
    <string name="perm_accessibility_desc">Allows the app to type into input fields of other apps.</string>
    <string name="perm_overlay">2. Display over other apps</string>
    <string name="perm_overlay_desc">Shows the floating ①②★ panel on top of other apps.</string>
    <string name="enable">Enable</string>
    <string name="enabled">Enabled ✓</string>

    <!-- Floating control -->
    <string name="start_floating">Show floating buttons</string>
    <string name="stop_floating">Hide floating buttons</string>
    <string name="open_settings">Settings</string>

