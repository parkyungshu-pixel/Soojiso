<?xml version="1.0" encoding="utf-8"?>
<!--
  Pop-up shown as an overlay when user taps the 📌 button.
  Contains a vertical list of pinned values. Tapping one fills
  the currently focused input via the Accessibility service.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/picker_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/pin_picker_bg"
    android:elevation="16dp"
    android:padding="8dp"
    android:minWidth="220dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="6dp"
        android:text="Pinned items"
        android:textColor="@color/on_primary"
        android:textStyle="bold"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/pin_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

    <TextView
        android:id="@+id/pin_close"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:padding="10dp"
        android:gravity="center"
        android:text="Cancel"
        android:textColor="@color/on_primary"
        android:textSize="13sp"
        android:background="?android:attr/selectableItemBackground" />
</LinearLayout>
