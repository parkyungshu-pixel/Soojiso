<?xml version="1.0" encoding="utf-8"?>
<!--
  Three stacked circular buttons. The LinearLayout itself has no
  touch listener; each child button has its own, so drags and taps
  land on the right button even though the whole column is movable.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floating_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="4dp">

    <TextView
        android:id="@+id/btn_fill_1"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:layout_marginBottom="6dp"
        android:background="@drawable/floating_button_bg"
        android:gravity="center"
        android:text="1"
        android:textColor="@color/on_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:elevation="8dp"
        android:contentDescription="Fill first input" />

    <TextView
        android:id="@+id/btn_fill_2"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:layout_marginBottom="6dp"
        android:background="@drawable/floating_button_bg"
        android:gravity="center"
        android:text="2"
        android:textColor="@color/on_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:elevation="8dp"
        android:contentDescription="Fill second input" />

    <TextView
        android:id="@+id/btn_fill_password"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:layout_marginBottom="6dp"
        android:background="@drawable/floating_button_bg"
        android:gravity="center"
        android:text="🔒"
        android:textColor="@color/on_primary"
        android:textSize="22sp"
        android:elevation="8dp"
        android:contentDescription="Fill password" />

    <TextView
        android:id="@+id/btn_keep"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:background="@drawable/floating_button_bg"
        android:gravity="center"
        android:text="★"
        android:textColor="@color/sakura_gold"
        android:textSize="26sp"
        android:elevation="8dp"
        android:contentDescription="Keep last filled item" />

</LinearLayout>
