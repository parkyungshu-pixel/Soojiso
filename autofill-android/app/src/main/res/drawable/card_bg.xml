<?xml version="1.0" encoding="utf-8"?>
<!-- Elevated card surface with a soft gold top accent line. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/ink_surface" />
            <corners android:radius="14dp" />
            <stroke
                android:width="1dp"
                android:color="@color/ink_divider" />
        </shape>
    </item>
</layer-list>
